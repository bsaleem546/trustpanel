# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=Host=localhost;Port=5432;Database=trustpanel;Username=trustpanel;Password=CHANGE_ME

# docker-compose postgres service credentials (used by the postgres container)
POSTGRES_DB=trustpanel
POSTGRES_USER=trustpanel
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CONNECTION=localhost:6379,password=CHANGE_ME,ssl=False
REDIS_PASSWORD=CHANGE_ME

# ── JWT / Auth ────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_at_least_64_random_chars_here_for_HS256
JWT_ISSUER=https://api.trustpanel.io
JWT_AUDIENCE=https://app.trustpanel.io
# Access token lifetime in minutes (15 recommended)
JWT_EXPIRY_MINUTES=15

# ── Data Protection (refresh-token cookie encryption) ─────────────────────────
DATA_PROTECTION_KEYS_PATH=/app/keys

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_STARTER_MONTHLY_PRICE_ID=price_CHANGE_ME
STRIPE_STARTER_ANNUAL_PRICE_ID=price_CHANGE_ME
STRIPE_GROWTH_MONTHLY_PRICE_ID=price_CHANGE_ME
STRIPE_GROWTH_ANNUAL_PRICE_ID=price_CHANGE_ME
STRIPE_AGENCY_MONTHLY_PRICE_ID=price_CHANGE_ME
STRIPE_AGENCY_ANNUAL_PRICE_ID=price_CHANGE_ME

# ── Resend (transactional email) ──────────────────────────────────────────────
RESEND_API_KEY=re_CHANGE_ME
RESEND_FROM_EMAIL=noreply@mail.trustpanel.io
RESEND_WEBHOOK_SECRET=CHANGE_ME

# ── Cloudflare R2 (video / asset storage) ─────────────────────────────────────
R2_ACCOUNT_ID=CHANGE_ME
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_BUCKET_NAME=trustpanel-uploads
R2_PUBLIC_BASE_URL=https://cdn.trustpanel.io

# ── Meilisearch ───────────────────────────────────────────────────────────────
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=CHANGE_ME

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_INSIGHTS_MODEL=claude-sonnet-4-6

# ── Cloudflare Turnstile ──────────────────────────────────────────────────────
TURNSTILE_SECRET_KEY=CHANGE_ME

# ── Google OAuth (optional) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=https://CHANGE_ME@o0.ingest.sentry.io/0
SENTRY_RELEASE=1.0.0

# ── Hangfire ─────────────────────────────────────────────────────────────────
HANGFIRE_WORKER_COUNT=5

# ── Super admin bootstrap ─────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL=admin@trustpanel.io
SUPER_ADMIN_TEMP_PASSWORD=CHANGE_ME_strong_password

# ── Video upload limits ───────────────────────────────────────────────────────
MAX_VIDEO_UPLOAD_MB=100
