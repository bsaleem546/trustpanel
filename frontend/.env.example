# ── API proxy target ──────────────────────────────────────────────────────────
# Leave empty in development — Vite proxies /api/* to http://localhost:5065
# automatically (see vite.config.ts).
#
# Set this to your backend's public URL in production:
#   VITE_API_BASE_URL=https://api.trustpanel.io
VITE_API_BASE_URL=
